          "format": "table",
          "instant": true,
          "interval": "",
          "legendFormat": "{{instance}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "HTTP Status (last 5m)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "keepLabels": [
              "instance"
            ],
            "mode": "columns"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "Value",
                "instance"
              ]
            }
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "probe_http_status_code",
            "renamePattern": "HTTP Status"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "instance",
            "renamePattern": "Target"
