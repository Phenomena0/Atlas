    {
      "datasource": "Prometheus",
      "description": "Most recent HTTP status code observed (useful for auth/redirect surprises).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [
            {
              "options": {
                "200": {
                  "color": "green",
                  "index": 0,
                  "text": "OK"
                },
                "401": {
                  "color": "yellow",
                  "index": 1,
                  "text": "Unauthorized"
                },
                "403": {
                  "color": "orange",
                  "index": 2,
                  "text": "Forbidden"
                },
                "404": {
                  "color": "orange",
                  "index": 3,
                  "text": "Not Found"
                },
                "500": {
                  "color": "red",
                  "index": 4,
                  "text": "Server Error"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "#EAB839",
                "value": 401
              },
              {
                "color": "orange",
                "value": 403
              },
              {
                "color": "orange",
                "value": 404
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
